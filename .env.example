# Copy to .env and change for production
POSTGRES_DB=woodsos
POSTGRES_USER=woodsos
POSTGRES_PASSWORD=change-me-please
JWT_SECRET=dev-secret-change-me
TZ=America/Toronto
WOODSOS_HTTP_PORT=8800

# First-boot admin account (created only if no users exist)
ADMIN_EMAIL=admin@muskokawoods.com
ADMIN_PASSWORD=WoodsOS!demo

# Seed a full demo workspace on first boot (roster, bookings, tickets, tasks...)
SEED_DEMO_DATA=true

# Optional: enables Claude triage of guest-submitted facility reports.
# Leave empty to use the built-in keyword triage (no external calls).
ANTHROPIC_API_KEY=
